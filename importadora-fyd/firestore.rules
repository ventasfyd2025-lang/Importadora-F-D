rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Productos - lectura pública, escritura solo administradores
    match /products/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Categorías - lectura pública, escritura solo administradores
    match /categories/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Categorías (español) - lectura pública, escritura solo administradores
    match /categorias/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Pedidos - creación pública, lectura/edición solo administradores
    match /orders/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    // Configuración - lectura pública, escritura solo administradores
    match /config/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Usuarios - cada usuario puede leer/escribir solo su propio documento
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Mensajes de chat - usuarios autenticados pueden acceder
    match /chat_messages/{document} {
      allow read, write, create: if request.auth != null;
    }
    
    // Reportes diarios - solo administradores pueden leer/escribir
    match /daily_reports/{document} {
      allow read, write: if request.auth != null;
    }
  }
}